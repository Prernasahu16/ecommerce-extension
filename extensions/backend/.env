# ============================================================
# EXTENSION LAYER — .env.example
# Copy to backend/.env and fill in values.
# All extension vars prefixed EXT_ or use existing names.
# ============================================================

# ── Database (reuse existing) ────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce
# OR individual vars (whichever your db.py uses):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres 
DB_PASSWORD=postgres

# ── Flask ────────────────────────────────────────────────────
FLASK_DEBUG=false
PORT=5000

# ── JWT Authentication ───────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-random-32-char-string
JWT_EXPIRY_HOURS=24
PASSWORD_PEPPER=change-me-random-pepper-string

# ── Amazon API (RapidAPI) ────────────────────────────────────
# Get key at: https://rapidapi.com/search/real-time-amazon-data
# Leave blank to use mock data (FakeStore free API always works)
RAPIDAPI_KEY=

# ── Flipkart Scraping (ScraperAPI) ───────────────────────────
# Get key at: https://www.scraperapi.com (free tier: 5000 req/mo)
# Leave blank to use mock data
SCRAPERAPI_KEY=

# ── Extension Scheduler ──────────────────────────────────────
# How often to recompute advanced_value_scores (in hours)
EXT_SCORE_INTERVAL_HOURS=2
# How often to check price alerts (in hours)
EXT_ALERT_INTERVAL_HOURS=4
